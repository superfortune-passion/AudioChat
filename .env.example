# Server (Render)
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Client (Vercel) — prefix with VITE_
# Leave unset for local dev; auto-uses same host as the page (works on LAN)
# VITE_SOCKET_URL=http://192.168.1.100:3000
VITE_STUN_URL=stun:stun.l.google.com:19302

# Optional TURN server (required for many NAT/firewall scenarios in production)
# VITE_TURN_URL=turn:your-turn-server.com:3478
# VITE_TURN_USERNAME=your-username
# VITE_TURN_CREDENTIAL=your-credential
